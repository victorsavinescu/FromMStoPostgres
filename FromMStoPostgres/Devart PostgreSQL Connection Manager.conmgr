<?xml version="1.0"?>
<DTS:ConnectionManager xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:ObjectName="Devart PostgreSQL Connection Manager"
  DTS:DTSID="{6187CC0B-84D2-4012-A28B-48EB944B584D}"
  DTS:CreationName="DevartPostgreSql">
  <DTS:ObjectData>
    <PostgreSqlConnectionManager
      ConnectByProxy="False">
      <ConnectionString>User Id=postgres;Host=localhost;Database=postgres;Persist Security Info=True;Initial Schema=dbo</ConnectionString>
      <Password
        Sensitive="1"></Password>
    </PostgreSqlConnectionManager>
  </DTS:ObjectData>
</DTS:ConnectionManager>